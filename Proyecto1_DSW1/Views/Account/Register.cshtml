@model Proyecto1_DSW1.Models.UsuarioModel

@{
    ViewData["Title"] = "Registro de usuario";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-header text-white fw-bold" style="background-color:#1a6b3c;">
                👤 Crear una cuenta nueva
            </div>
            <div class="card-body p-4">

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-semibold"></label>
                        <input asp-for="Nombre" class="form-control" placeholder="Ej: Juan Pérez" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Correo" class="form-label fw-semibold"></label>
                        <input asp-for="Correo" class="form-control" placeholder="correo@ejemplo.com" />
                        <span asp-validation-for="Correo" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Contrasena" class="form-label fw-semibold"></label>
                        <input asp-for="Contrasena" class="form-control" placeholder="Mínimo 4 caracteres" />
                        <span asp-validation-for="Contrasena" class="text-danger small"></span>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-success btn-lg">Registrarme</button>
                    </div>
                </form>

            </div>
            <div class="card-footer text-center text-muted small">
                ¿Ya tienes cuenta? <a asp-controller="Home" asp-action="Index">Volver al inicio</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
